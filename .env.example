# ============================================================
# CIOS Environment Configuration
# Copy to .env.local and populate for your environment
# NEVER commit real values to version control
# ============================================================

# --- Application ---
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
AGENT_RUNTIME_URL=http://localhost:8001

# --- Database ---
DATABASE_URL=postgresql+asyncpg://cios_user:cios_pass@localhost:5432/cios_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# --- Qdrant (Vector Database) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key

# --- Anthropic AI ---
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL_CEO=claude-opus-4-8
ANTHROPIC_MODEL_DIRECTOR=claude-sonnet-4-6
ANTHROPIC_MODEL_ANALYST=claude-haiku-4-5-20251001

# --- Authentication (Supabase) ---
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
JWT_SECRET=your_jwt_secret_minimum_32_chars

# --- S3-Compatible Storage ---
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_DOCUMENTS=cios-documents
S3_BUCKET_EXPORTS=cios-exports
S3_REGION=us-east-1

# --- External Data Sources ---
SAM_GOV_API_KEY=your_sam_gov_api_key
USASpending_API_KEY=your_usaspending_api_key
FPDS_API_KEY=your_fpds_api_key

# --- Encryption ---
ENCRYPTION_KEY=your_32_byte_hex_encryption_key
TENANT_KEY_DERIVATION_SALT=your_salt_value

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=INFO

# --- Billing (Stripe) ---
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PROFESSIONAL=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# --- Email ---
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@cios.ai

# --- Feature Flags ---
FEATURE_AWARD_SIMULATOR=true
FEATURE_COMPETITIVE_INTEL=true
FEATURE_TEAMING_AI=true
