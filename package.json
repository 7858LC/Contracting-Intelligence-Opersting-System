{
  "name": "cios",
  "version": "1.0.0",
  "private": true,
  "description": "Contract Intelligence Operating System — The Bloomberg Terminal of Procurement",
  "repository": {
    "type": "git",
    "url": "https://github.com/7858lc/contracting-intelligence-opersting-system"
  },
  "homepage": "https://github.com/7858lc/contracting-intelligence-opersting-system#readme",
  "bugs": {
    "url": "https://github.com/7858lc/contracting-intelligence-opersting-system/issues"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "cd apps/api && alembic upgrade head",
    "db:rollback": "cd apps/api && alembic downgrade -1",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "docker:build": "docker compose -f infra/docker/docker-compose.yml build"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
